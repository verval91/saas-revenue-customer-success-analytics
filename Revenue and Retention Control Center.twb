      <aliases enabled='yes' />
      <column caption='Churn Risk Flag' datatype='string' name='[Calculation_1938628611559424]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [nps_score] &lt; 5 OR [support_tickets] &gt; 5 THEN &quot;High Risk&quot; ELSE &quot;Healthy&quot; END' />
      </column>
      <column caption='Revenue Type Value' datatype='integer' name='[Calculation_1938628614569985]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Revenue Type Value&#10;CASE [event_type]&#10;    WHEN &quot;New Business&quot; THEN [arr_usd]&#10;    WHEN &quot;Expansion&quot; THEN [arr_usd]&#10;    WHEN &quot;Contraction&quot; THEN -[arr_usd] // Itt negatív értékként kezeljük a csökkenést&#10;    WHEN &quot;Full Churn&quot; THEN -[arr_usd]   // És a távozást is&#10;    ELSE 0&#10;END' />
      </column>
      <column caption='Starting ARR' datatype='integer' name='[Calculation_1938628614717442]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [event_type] = &quot;New Business&quot; THEN [arr_usd] END)' />
      </column>
      <column caption='Negatvie Value' datatype='integer' name='[Calculation_1938628614803459]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='-SUM([Calculation_1938628614569985])' />
      </column>
      <column caption='NRR %' datatype='real' default-format='p0.00%' name='[Calculation_1938628614914052]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// NRR %&#10;(SUM(IF [event_type] != &quot;New Business&quot; THEN [Calculation_1938628614569985] END) &#10;+ SUM(IF [event_type] = &quot;New Business&quot; THEN [arr_usd] END))&#10;/ &#10;SUM(IF [event_type] = &quot;New Business&quot; THEN [arr_usd] END)' />
      </column>
      <column caption='API Usage Growth %' datatype='real' name='[Calculation_1938628623785990]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([api_usage_calls]) - LOOKUP(SUM([api_usage_calls]), -1)) &#10;/ &#10;ABS(LOOKUP(SUM([api_usage_calls]), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Customer Heath Category' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_1938628624068615]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1938628624375816] &gt;= 8 AND [Calculation_1938628624560137] &gt; 0 THEN &quot;Champions&quot;&#10;ELSEIF [Calculation_1938628624375816] &lt;= 5 THEN &quot;High Churn Risk&quot;&#10;ELSEIF [Calculation_1938628624560137] &lt; -0.2 THEN &quot;At-Risk (Declining Usage)&quot;&#10;ELSE &quot;Healthy / Stable&quot;&#10;END' />
      </column>
      <column caption='Latest NPS Score' datatype='integer' name='[Calculation_1938628624375816]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_id] : MAX(IF [month] = { FIXED [customer_id] : MAX([month]) } THEN [nps_score] END) }' />
      </column>
      <column caption='Usage Growth (June vs Jan)' datatype='real' name='[Calculation_1938628624560137]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='({ FIXED [customer_id] : SUM(IF [month] = #2024-06-01# THEN [api_usage_calls] END)} &#10;- &#10;{ FIXED [customer_id] : SUM(IF [month] = #2024-01-01# THEN [api_usage_calls] END)})&#10;/&#10;{ FIXED [customer_id] : SUM(IF [month] = #2024-01-01# THEN [api_usage_calls] END)}' />
      </column>
      <column caption='Retained + Expanded ARR' datatype='integer' name='[Retained + Expanded ARR (copy)_1938628615229445]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1938628614569985])' />
      </column>
      <column caption='dim_customers.csv' datatype='table' name='[__tableau_internal_object_id__].[dim_customers.csv_EB0C2D3AA6164A35AA9B00576B44F1A7]' role='measure' type='quantitative' />
      <column caption='fact_subscriptions.csv' datatype='table' name='[__tableau_internal_object_id__].[fact_subscriptions.csv_42C0B12842724D96B0C5D8B46B99710E]' role='measure' type='quantitative' />
      <column caption='fact_usage_health.csv' datatype='table' name='[__tableau_internal_object_id__].[fact_usage_health.csv_4D9E696F1D024237BBDCEF17CE48FF90]' role='measure' type='quantitative' />
      <column caption='Active Users' datatype='integer' name='[active_users]' role='measure' type='quantitative' />
      <column caption='Api Usage Calls' datatype='integer' name='[api_usage_calls]' role='measure' type='quantitative' />
