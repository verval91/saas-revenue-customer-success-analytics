              <calculation class='tableau' formula='// NRR %&#10;(SUM(IF [event_type] != &quot;New Business&quot; THEN [Calculation_1938628614569985] END) &#10;+ SUM(IF [event_type] = &quot;New Business&quot; THEN [arr_usd] END))&#10;/ &#10;SUM(IF [event_type] = &quot;New Business&quot; THEN [arr_usd] END)' />
